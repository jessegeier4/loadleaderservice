rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ─── USERS ───
    // Each user can read/write only their own user document.
    // Public read of basic profile info (firstName, lastName, state, rating) is allowed
    // so carriers can display pilot profiles on applications.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      // Cross-user update is intentionally narrow — only rating + reviewCount, with
      // bounds-checking to prevent obvious tanking/inflation attacks (rating in 0-5,
      // reviewCount only increases). This is NOT a full fix — any signed-in user can still
      // submit a single bogus rating overwrite. The proper fix is to forbid client-side
      // rating writes entirely and recompute server-side via a Cloud Function on
      // reviews/{id} create. Tracked separately.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount'])
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && request.resource.data.reviewCount is int
        && request.resource.data.reviewCount >= 0
        && (resource.data.reviewCount == null || request.resource.data.reviewCount >= resource.data.reviewCount);
    }

    // ─── LOADS ───
    // Anyone signed in can read loads (public load board).
    // Only the carrier who owns the load can create/update/delete it.
    match /loads/{loadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.carrierId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.carrierId == request.auth.uid;
    }

    // ─── APPLICATIONS ───
    // Pilot creates their own application. Both pilot and carrier on the load can read.
    // Pilot can update their own (e.g. log day, log expense). Carrier can update status (accept/decline).
    match /applications/{appId} {
      allow read: if isSignedIn() && (
        resource.data.pilotId == request.auth.uid ||
        resource.data.carrierId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.pilotId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.pilotId == request.auth.uid ||
        resource.data.carrierId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.pilotId == request.auth.uid ||
        resource.data.carrierId == request.auth.uid
      );
    }

    // ─── INVOICES ───
    // Pilot creates invoice on delivery. Both pilot and carrier can read.
    // No updates or deletes after generation (immutable record).
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        resource.data.pilotId == request.auth.uid ||
        resource.data.carrierId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.pilotId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.pilotId == request.auth.uid ||
        resource.data.carrierId == request.auth.uid
      );
    }

    // ─── SAVED LOADS ───
    // Pilot only — saved/favorited loads.
    match /savedLoads/{docId} {
      allow read, write: if isSignedIn() && resource.data.pilotId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.pilotId == request.auth.uid;
    }

    // ─── LOAD TEMPLATES ───
    // Carrier only — saved post-a-load templates.
    match /loadTemplates/{docId} {
      allow read, write: if isSignedIn() && resource.data.carrierId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.carrierId == request.auth.uid;
    }

    // ─── NOTIFICATIONS ───
    // Each user reads their own. Anyone signed in can create FOR ANOTHER USER (the system flow:
    // pilot applies → notification for carrier; carrier accepts → notification for pilot).
    // Bounds prevent obvious abuse: type must be one of the known values, message length capped,
    // userId must differ from sender (no self-spam loops), createdAt must be a server timestamp.
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.userId != request.auth.uid
        && request.resource.data.type in [
          'new_application','application_accepted','application_declined',
          'pilot_removed','declined',
          'new_message','message',
          'invoice','delivery_confirmed',
          'load_alert','fleet_load',
          'review','generic'
        ]
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500
        && request.resource.data.read == false;
    }

    // ─── CONVERSATIONS ───
    match /conversations/{convId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
    }

    // ─── MESSAGES (top-level collection, linked by conversationId) ───
    match /messages/{msgId} {
      allow read: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants;
      allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // ─── FLEET / FOLLOWS ───
    match /fleet/{docId} {
      allow read, write: if isSignedIn() && resource.data.carrierId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.carrierId == request.auth.uid;
    }
    match /follows/{docId} {
      allow read, write: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
    }

    // ─── REVIEWS ───
    // Anyone signed in can read reviews. Both pilots and carriers can create
    // reviews — verified by reviewerId matching their auth uid.
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
    }

    // ─── PERMITS ───
    // Carrier writes permits for their loads. All signed-in users can read (so pilots see them).
    match /permits/{permitId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && resource.data.carrierId == request.auth.uid;
    }
  }
}

// ─── DEPLOYMENT ───
// 1. Install Firebase CLI if you do not have it: `npm install -g firebase-tools`
// 2. From the project root: `firebase login`
// 3. Initialize firestore once: `firebase init firestore` (select the load-leader project, accept defaults)
// 4. Deploy these rules: `firebase deploy --only firestore:rules`
//
// OR via the Firebase Console:
// - Go to https://console.firebase.google.com/project/load-leader/firestore/rules
// - Paste the contents above (everything before this comment block)
// - Click Publish
//
// After deploying, test that:
// - A signed-in carrier can see only their own loads in the dashboard
// - A signed-in pilot can apply to a load and see their own applications
// - A carrier can read applications for their own loads (the loadId-in query was failing — this fixes it)
// - Two unrelated users cannot read each other's user docs, applications, or invoices
